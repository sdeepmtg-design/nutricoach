BOT_TOKEN=your_telegram_bot_token
# Локально: polling (по умолчанию). На Render: webhook (в render.yaml)
BOT_MODE=polling
# Опционально для локального теста webhook:
# WEBHOOK_URL=https://nutricoach-bot.onrender.com
# WEBHOOK_SECRET=optional_secret
OPENAI_API_KEY=your_openai_key_optional
ADMIN_IDS=123456789
DATABASE_PATH=data/nutricoach.db

# Telegram Stars (XTR) — цены в звёздах
PRO_MONTH_STARS=150
PRO_YEAR_STARS=1200

# Лимиты Free
FREE_PHOTOS_PER_DAY=3
FREE_PHOTOS_PER_MONTH=30
FREE_AI_MESSAGES_PER_DAY=5

# Лимиты Pro (0 = без лимита)
PRO_PHOTOS_PER_DAY=50
PRO_AI_MESSAGES_PER_DAY=100
